local function awardCoins(player, amount, reason)
	local data = player:FindFirstChild("PlayerData")
	if data then
		local coins = data:FindFirstChild("Coins")
		if coins then
			coins.Value = math.max(0, coins.Value + amount)
			evUpdateCoins:FireClient(player, amount, reason)
		end
	end
end


