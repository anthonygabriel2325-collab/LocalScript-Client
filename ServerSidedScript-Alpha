evSurv1Reveal.OnServerInvoke = function(player)
	if not table.find(survivors, player) then return {} end
	local revealedKillers = {}

	for _, k in ipairs(activeKillers) do
		local char = k.Character
		if char then
			local head = char:FindFirstChild("Head")
			-- Checa se o Killer não está invisível (Head transparency menor que 0.9)
			if head and head.Transparency < 0.9 then
				table.insert(revealedKillers, char)
			end
		end
	end

	return revealedKillers
end


evSurv2Throw.OnServerEvent:Connect(function(player, targetPos)
	if not table.find(survivors, player) then return end
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	local block = Instance.new("Part")
	block.Size = Vector3.new(3, 3, 3)
	block.Color = Color3.fromRGB(0, 255, 255) -- Cor do bloco (Neon)
	block.Material = Enum.Material.Neon
	block.Anchored = true
	block.CanCollide = false
	block.CFrame = root.CFrame * CFrame.new(0, 0, -3)
	block.Parent = Workspace

	local direction = (targetPos - root.Position).Unit
	local speed = 60
	local duration = 2
	local startTime = tick()
	local hitKiller = false

	task.spawn(function()
		while tick() - startTime < duration do
			if not block.Parent then break end
			block.CFrame = block.CFrame + direction * (speed * task.wait())

			local hitParts = Workspace:GetPartBoundsInBox(block.CFrame, block.Size)
			for _, p in ipairs(hitParts) do
				local pChar = p.Parent
				local kPlayer = Players:GetPlayerFromCharacter(pChar)

				-- Se acertou um killer ativo
				if kPlayer and table.find(activeKillers, kPlayer) then
					hitKiller = true
					local hum = pChar:FindFirstChild("Humanoid")
					if hum then
						local oldSpeed = hum.WalkSpeed
						hum.WalkSpeed = 8 -- Deixa lento
						task.delay(2, function()
							if hum then hum.WalkSpeed = oldSpeed end
						end)
					end
					break
				end
			end
			if hitKiller then break end
		end
		block:Destroy()
	end)
end)


