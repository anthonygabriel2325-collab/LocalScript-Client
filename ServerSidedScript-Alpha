local function applyMorph(player, morphName, spawnPart)
	local template = ServerStorage:FindFirstChild(morphName)
	if not template then
		warn("Faltou o modelo: " .. morphName)
		return
	end

	local oldChar = player.Character or player.CharacterAdded:Wait()
	local charClone = template:Clone()
	charClone.Name = player.Name

	local animate = oldChar:FindFirstChild("Animate")
	if animate then
		local newAnim = animate:Clone()
		newAnim.Parent = charClone
		newAnim.Disabled = true
		task.delay(0.1, function()
			newAnim.Disabled = false
		end)
	end

	local hum = charClone:WaitForChild("Humanoid")
	hum.BreakJointsOnDeath = false

	for _, obj in ipairs(charClone:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then
			obj:Destroy()
		end
	end

	player.Character = charClone
	charClone.Parent = Workspace

	if spawnPart then
		local root = charClone:FindFirstChild("HumanoidRootPart") or charClone:FindFirstChild("Torso")
		if root then
			root.CFrame = spawnPart.CFrame * CFrame.new(0, 3, 0)
		end
	end

	oldChar:Destroy()
end


task.spawn(function()
	while true do
		inRound = false
		table.clear(activeKillers)
		table.clear(survivors)
		table.clear(killerStates)
		local lmsTriggered = false
		local oneBounceLMSFired = false
		specialMode = "Normal"
		chaseThemeActive.Value = true

		for i = INTERMISSION_TIME, 0, -1 do
			status.Value = "Intermissão: " .. i .. "s"
			task.wait(1)
		end

		local plrs = Players:GetPlayers()
		if #plrs < MIN_PLAYERS then
			status.Value = "Mínimo 2 jogadores!"
			task.wait(3)
			continue
		end

		-- Lógica da Roleta a cada 3 rounds
		roundCount += 1
		if roundCount % 3 == 0 then
			local modes = {"OneBounce", "Espiao", "DoubleTrouble"}
			if #plrs < 3 then
				modes = {"OneBounce", "Espiao"}
			end

			specialMode = modes[math.random(1, #modes)]
			evSpecialRoulette:FireAllClients(specialMode)
			status.Value = "Sorteando Round Especial..."
			task.wait(6)
		end

		if specialMode == "Espiao" then
			chaseThemeActive.Value = false
		end

		status.Value = "Preparando a arena..."
		evTransition:FireAllClients("FadeIn")
		task.wait(1.5)

		-- Atribuição de Papéis
		if specialMode == "OneBounce" then
			local theSurvivor = plrs[math.random(1, #plrs)]
			table.insert(survivors, theSurvivor)
			for _, p in ipairs(plrs) do
				if p ~= theSurvivor then
					table.insert(activeKillers, p)
					killerStates[p] = {isHunter = false}
				end
			end
		elseif specialMode == "DoubleTrouble" and #plrs >= 3 then
			local k1 = plrs[math.random(1, #plrs)]
			local k2
			repeat
				k2 = plrs[math.random(1, #plrs)]
			until k2 ~= k1

			table.insert(activeKillers, k1)
			table.insert(activeKillers, k2)
			killerStates[k1] = {isHunter = false}
			killerStates[k2] = {isHunter = false}

			for _, p in ipairs(plrs) do
				if p ~= k1 and p ~= k2 then
					table.insert(survivors, p)
				end
			end
		else
			local k = plrs[math.random(1, #plrs)]
			table.insert(activeKillers, k)
			killerStates[k] = {isHunter = false}
			for _, p in ipairs(plrs) do
				if p ~= k then
					table.insert(survivors, p)
				end
			end
		end

		local spawnsFolder = Workspace:FindFirstChild("ArenaSpawns")
		local spawnList = {}
		if spawnsFolder then
			spawnList = spawnsFolder:GetChildren()
		else
			local fallbackSpawn = Workspace:FindFirstChild("ArenaSpawn")
			if fallbackSpawn then table.insert(spawnList, fallbackSpawn) end
		end

		for _, p in ipairs(plrs) do
			local randomSpawn = nil
			if #spawnList > 0 then
				randomSpawn = spawnList[math.random(1, #spawnList)]
			end

			local isK = table.find(activeKillers, p) ~= nil

			-- Setup Morphs e Habilidades (Passando o nome do personagem equipado na UI)
			if specialMode == "Espiao" then
				if randomSpawn then
					local root = p.Character and (p.Character:FindFirstChild("HumanoidRootPart") or p.Character:FindFirstChild("Torso"))
					if root then
						root.CFrame = randomSpawn.CFrame * CFrame.new(0, 3, 0)
					end
				end

				if isK then
					local kName = p.PlayerData.EquippedKiller.Value
					local maxStam = CHARACTERS.Killers[kName].Stamina
					task.delay(1, function()
						toggleKillerUI:FireClient(p, "Killer", kName, maxStam)
					end)
				else
					local sName = p.PlayerData.EquippedSurvivor.Value
					local maxStam = CHARACTERS.Survivors[sName].Stamina
					toggleKillerUI:FireClient(p, "Survivor", sName, maxStam)
				end
			else
				if isK then
					local kMorph = p.PlayerData.EquippedKiller.Value
					applyMorph(p, kMorph, randomSpawn)
					local maxStam = CHARACTERS.Killers[kMorph].Stamina
					task.delay(1, function()
						toggleKillerUI:FireClient(p, "Killer", kMorph, maxStam)
					end)
				else
					local sMorph = p.PlayerData.EquippedSurvivor.Value
					applyMorph(p, sMorph, randomSpawn)
					local maxStam = CHARACTERS.Survivors[sMorph].Stamina
					toggleKillerUI:FireClient(p, "Survivor", sMorph, maxStam)
				end
			end

			local char = p.Character
			if char then
				-- Configurando colisão para não bugar com a parede do Surv 5
				for _, part in ipairs(char:GetDescendants()) do
					if part:IsA("BasePart") then
						pcall(function() PhysicsService:SetPartCollisionGroup(part, isK and "Killers" or "Survivors") end)
					end
				end

				local hum = char:WaitForChild("Humanoid")
				local root = char:WaitForChild("HumanoidRootPart")

				hum.WalkSpeed = 0
				hum.UseJumpPower = true
				hum.JumpPower = 0
				hum.JumpHeight = 0
				root.Anchored = true 
				hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)

				task.spawn(function()
					for i = 1, 30 do 
						if not char or not char.Parent or inRound then break end
						hum.JumpPower = 0
						hum.WalkSpeed = 0
						task.wait(0.2)
					end
				end)
			end
		end

		evTransition:FireAllClients("Countdown", 5)
		for i = 5, 1, -1 do
			status.Value = "Começando em: " .. i
			task.wait(1)
		end

		for _, p in ipairs(plrs) do
			task.spawn(function()
				local char = p.Character
				if char then
					local hum = char:FindFirstChild("Humanoid")
					local root = char:FindFirstChild("HumanoidRootPart")
					if hum and root then
						root.Anchored = false 
						hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true) 
						hum.UseJumpPower = true
						hum.JumpPower = 50

						local isK = table.find(activeKillers, p) ~= nil

						if isK then
							local kName = p.PlayerData.EquippedKiller.Value
							hum.WalkSpeed = CHARACTERS.Killers[kName].Speed
						else
							local sName = p.PlayerData.EquippedSurvivor.Value
							local sSpeed = CHARACTERS.Survivors[sName].Speed
							if specialMode == "OneBounce" then
								sSpeed = sSpeed + 6
								hum.MaxHealth = 200
								hum.Health = 200
							end
							hum.WalkSpeed = sSpeed
						end
					end
				end
			end)
		end

		evTransition:FireAllClients("FadeOut")
		status.Value = "Partida Iniciada!"
		timeLeft.Value = ROUND_TIME
		inRound = true

		while inRound and timeLeft.Value > 0 do
			local aliveCount = 0
			local lastAlivePlayer = nil
			for _, s in ipairs(survivors) do
				if s.Character and s.Character:FindFirstChild("Humanoid") and s.Character.Humanoid.Health > 1 then
					aliveCount += 1
					lastAlivePlayer = s
				end
			end

			local killersAlive = 0
			for _, k in ipairs(activeKillers) do
				if k.Character and k.Character:FindFirstChild("Humanoid") and k.Character.Humanoid.Health > 1 then
					killersAlive += 1
				end
			end

			if aliveCount == 0 then
				status.Value = "O Assassino Venceu!"
				for _, k in ipairs(activeKillers) do
					awardCoins(k, 50, "Vitória")
				end
				evGameOver:FireAllClients("Killer")
				task.wait(2)
				break
			end

			if killersAlive == 0 then
				status.Value = "Sobreviventes Venceram!"
				for _, s in ipairs(survivors) do
					if s.Character and s.Character:FindFirstChild("Humanoid") and s.Character.Humanoid.Health > 1 then
						awardCoins(s, 50, "Vitória")
					end
				end
				evGameOver:FireAllClients("Survivor")
				task.wait(2)
				break
			end

			if specialMode == "OneBounce" and (ROUND_TIME - timeLeft.Value) >= 10 and not oneBounceLMSFired then
				oneBounceLMSFired = true
				timeLeft.Value = 90
				status.Value = "LAST MAN STANDING!"
				local kName = activeKillers[1] and activeKillers[1].PlayerData.EquippedKiller.Value or "Killer1"
				local sName = lastAlivePlayer and lastAlivePlayer.PlayerData.EquippedSurvivor.Value or "Survivor1"
				evLMS:FireAllClients(kName, sName)
				lmsTriggered = true
			end

			if aliveCount == 1 and not lmsTriggered and specialMode ~= "OneBounce" then
				lmsTriggered = true
				timeLeft.Value = 90
				status.Value = "LAST MAN STANDING!"
				local kName = activeKillers[1].PlayerData.EquippedKiller.Value
				local sName = lastAlivePlayer.PlayerData.EquippedSurvivor.Value
				evLMS:FireAllClients(kName, sName)
			end

			local mins, secs = math.floor(timeLeft.Value / 60), timeLeft.Value % 60
			status.Value = lmsTriggered and string.format("LMS - %02d:%02d", mins, secs) or string.format("Tempo: %02d:%02d", mins, secs)
			task.wait(1)
			timeLeft.Value -= 1
		end

		inRound = false
		evLMS:FireAllClients("STOP", "STOP")

		evTransition:FireAllClients("FadeIn")
		task.wait(1.5)

		for _, p in ipairs(Players:GetPlayers()) do
			toggleKillerUI:FireClient(p, "HIDE", nil, 100)
			p:LoadCharacter()
			task.wait(0.1)
			local lobby = Workspace:FindFirstChild("LobbySpawn")
			if p.Character and p.Character:FindFirstChild("Humanoid") then
				p.Character.Humanoid.WalkSpeed = 16
			end
			if p.Character and lobby then
				p.Character:PivotTo(lobby.CFrame)
			end
		end

		evTransition:FireAllClients("FadeOut")
	end
end)
print("ServerSide Script loaded with Success!")
