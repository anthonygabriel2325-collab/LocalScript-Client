evGetData.OnServerInvoke = function(player)
	local data = player:FindFirstChild("PlayerData")
	if not data then return nil end

	local ownedTable = {}
	for _, v in ipairs(data.Owned:GetChildren()) do
		ownedTable[v.Name] = true
	end

	return {
		Coins = data.Coins.Value,
		Owned = ownedTable,
		EqSurvivor = data.EquippedSurvivor.Value,
		EqKiller = data.EquippedKiller.Value
	}
end


evBuy.OnServerInvoke = function(player, charName)
	local data = player:FindFirstChild("PlayerData")
	if not data then return false, "Erro de dados" end
	if data.Owned:FindFirstChild(charName) then return false, "Já possui" end

	local charInfo = CHARACTERS.Survivors[charName] or CHARACTERS.Killers[charName]
	if not charInfo then return false, "Personagem não existe" end

	if data.Coins.Value >= charInfo.Price then
		data.Coins.Value -= charInfo.Price
		Instance.new("StringValue", data.Owned).Name = charName
		return true, "Comprado!"
	else
		return false, "Moedas insuficientes!"
	end
end


evEquip.OnServerInvoke = function(player, charName)
	local data = player:FindFirstChild("PlayerData")
	if not data then return false end
	if not data.Owned:FindFirstChild(charName) then return false end

	if CHARACTERS.Survivors[charName] then
		data.EquippedSurvivor.Value = charName
		return true
	elseif CHARACTERS.Killers[charName] then
		data.EquippedKiller.Value = charName
		return true
	end
	return false
end


local function setTransparency(char, value)
	for _, part in ipairs(char:GetDescendants()) do
		if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
			part.Transparency = value
		elseif part:IsA("Decal") then
			part.Transparency = value
		end
	end
end


local function showDamage(character, damage)
