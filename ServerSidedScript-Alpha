local function triggerExecuteSequence(victimChar, attackerChar, attackerPlayer)
	if not victimChar or not attackerChar then return end

	local victimRoot = victimChar:FindFirstChild("HumanoidRootPart") or victimChar:FindFirstChild("Torso")
	local attackerRoot = attackerChar:FindFirstChild("HumanoidRootPart") or attackerChar:FindFirstChild("Torso")

	if victimRoot then victimRoot.Anchored = true end
	if attackerRoot then attackerRoot.Anchored = true end

	local killerType = "Killer1"
	if attackerPlayer and attackerPlayer:FindFirstChild("PlayerData") then
		killerType = attackerPlayer.PlayerData.EquippedKiller.Value
	end

	local anims = DEATH_ANIMS[killerType] or DEATH_ANIMS["Killer1"]

	deathAnimEvent:FireAllClients(
		victimChar,
		attackerChar,
		anims.Victim,
		anims.Killer,
		EXECUTE_DURATION
	)

	task.delay(EXECUTE_DURATION, function()
		if victimChar and victimChar.Parent then
			local root = victimChar:FindFirstChild("HumanoidRootPart") or victimChar:FindFirstChild("Torso")
			if root then
				local explosion = Instance.new("Explosion")
				explosion.Position = root.Position
				explosion.BlastRadius = 8
				explosion.BlastPressure = 0
				explosion.DestroyJointRadiusPercent = 1
				explosion.Parent = Workspace
			end
			victimChar:Destroy()
		end

		if attackerRoot and attackerRoot.Parent then
			attackerRoot.Anchored = false
		end
	end)
end


local function customDamage(humanoid, amount, attackerPlayer)
	if humanoid.Health <= 0 then return end

	-- Lógica Habilidade Survivor 4 (Block)
	local char = humanoid.Parent
	if char and char:GetAttribute("Blocking") then
		humanoid.WalkSpeed = humanoid.WalkSpeed + 3
		task.delay(3, function()
			if humanoid and humanoid.Parent then
				humanoid.WalkSpeed = humanoid.WalkSpeed - 3
			end
		end)
		return -- Anula o dano
	end

	if humanoid.Health - amount <= 0 then
		if not char then return end

		if char:GetAttribute("Executing") then return end
		char:SetAttribute("Executing", true)

		local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
		if root then root.Anchored = true end

		humanoid.Health = 1
		humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)

		showDamage(char, amount)

		if attackerPlayer and attackerPlayer.Character then
			triggerExecuteSequence(char, attackerPlayer.Character, attackerPlayer)
		else
			task.delay(EXECUTE_DURATION, function()
				if char and char.Parent then
					local r = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
					if r then
						local explosion = Instance.new("Explosion")
						explosion.Position = r.Position
						explosion.BlastRadius = 8
						explosion.BlastPressure = 0
						explosion.DestroyJointRadiusPercent = 1
						explosion.Parent = Workspace
					end
					char:Destroy()
				end
			end)
		end

		if attackerPlayer and table.find(activeKillers, attackerPlayer) then
			awardCoins(attackerPlayer, 30, "Abate")
		end

		local victim = Players:GetPlayerFromCharacter(char)
		if victim then
			awardCoins(victim, -10, "Eliminado")
		end
	else
		humanoid:TakeDamage(amount)
		showDamage(humanoid.Parent, amount)
	end
end


evBlood.OnServerEvent:Connect(function(player)
	local char = player.Character
	if not char or not table.find(activeKillers, player) or not inRound then return end
	local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
	if not root then return end

	playAttackSound(char)

	local isDash = killerStates[player] and killerStates[player].isHunter
	if isDash then
		killerStates[player].isHunter = false
		local kName = player.PlayerData.EquippedKiller.Value
		char.Humanoid.WalkSpeed = CHARACTERS.Killers[kName].Speed
		setTransparency(char, 0)
		root:ApplyImpulse(root.CFrame.LookVector * 1500)
	end

	local hitboxSize = isDash and Vector3.new(6, 6, 12) or Vector3.new(5, 5, 5)

	local visualHitbox = Instance.new("Part")
	visualHitbox.Name = "BloodVisualHitbox"
	visualHitbox.Size = hitboxSize
	visualHitbox.Anchored = true
	visualHitbox.CanCollide = false
	visualHitbox.Material = Enum.Material.ForceField
	visualHitbox.Color = Color3.fromRGB(255, 0, 0) 
	visualHitbox.Transparency = 0.3
	visualHitbox.Parent = Workspace

	local hitHas = {}
	local duration = 0.5 
	local startTime = tick()

	task.spawn(function()
		while tick() - startTime < duration do
			if not root or not root.Parent then break end

			local hitboxCFrame = root.CFrame * (isDash and CFrame.new(0, 0, -6) or CFrame.new(0, 0, -3))
			visualHitbox.CFrame = hitboxCFrame 

			local parts = Workspace:GetPartBoundsInBox(hitboxCFrame, hitboxSize)
			for _, p in ipairs(parts) do
				-- Lógica Habilidade Survivor 5 (Destruir a Parede)
				if p.Name == "SurvWall" then
					local pos = p.Position
					p:Destroy()
					local exp = Instance.new("Explosion")
					exp.Position = pos
					exp.BlastRadius = 5
					exp.BlastPressure = 0
					exp.Parent = Workspace
					for i = 1, 10 do
						local frag = Instance.new("Part")
						frag.Size = Vector3.new(1.5, 1.5, 1.5)
						frag.Position = pos + Vector3.new(math.random(-2,2), 2, math.random(-2,2))
						frag.Velocity = Vector3.new(math.random(-40,40), 50, math.random(-40,40))
						frag.Color = Color3.fromRGB(100, 100, 100)
						frag.Parent = Workspace
						Debris:AddItem(frag, 2)
					end
					break -- Impede que o ataque atravesse a parede se acertar ela
				end

				local hum = p.Parent:FindFirstChild("Humanoid")
				if hum and not hitHas[hum] and p.Parent ~= char then
					hitHas[hum] = true
					customDamage(hum, isDash and 30 or 20, player)
				end
			end
			task.wait() 
		end
		visualHitbox:Destroy()
	end)
end)


