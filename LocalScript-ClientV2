	local slotText = Instance.new("TextLabel")
	slotText.Size = UDim2.new(1, 0, 0.7, 0)
	slotText.Position = UDim2.new(0, 0, 0.3, 0)
	slotText.Text = "..."
	slotText.TextColor3 = Color3.fromRGB(255, 255, 255)
	slotText.BackgroundTransparency = 1
	slotText.TextScaled = true
	slotText.Font = Enum.Font.GothamBold
	slotText.Parent = bg

	TweenService:Create(bg, TweenInfo.new(1, Enum.EasingStyle.Bounce), {Position = UDim2.new(0.3, 0, 0.1, 0)}):Play()
	task.wait(1)

	local modesDisplay = {
		["OneBounce"] = "ONE BOUNCE",
		["Espiao"] = "ESPIÃO",
		["DoubleTrouble"] = "DOUBLE TROUBLE",
	}

	for _ = 1, 20 do
		local r = {"ONE BOUNCE", "ESPIÃO", "DOUBLE TROUBLE"}
		slotText.Text = r[math.random(1, 3)]
		task.wait(0.1)
	end

	slotText.Text = modesDisplay[chosenMode] or tostring(chosenMode)
	slotText.TextColor3 = Color3.fromRGB(0, 255, 100)
	TweenService:Create(slotText, TweenInfo.new(0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, 0, true), {TextTransparency = 0.5}):Play()

	task.wait(2)
	TweenService:Create(bg, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(0.3, 0, -0.3, 0)}):Play()
	task.delay(1, function()
		if rGui then
			rGui:Destroy()
		end
	end)
end)

local function showCoinPopup(amount, reason, totalCoins)
	amount = tonumber(amount) or 0
	reason = reason or "Motivo"
	local popupGui = Instance.new("ScreenGui")
	popupGui.Name = "CoinPopup"
	popupGui.ResetOnSpawn = false
	popupGui.Parent = playerGui

	local textLabel = Instance.new("TextLabel")
	textLabel.Size = UDim2.new(0.4, 0, 0.1, 0)
	textLabel.Position = UDim2.new(0.3, 0, 0.2, 0)
	textLabel.BackgroundTransparency = 1
	textLabel.Font = Enum.Font.FredokaOne
	textLabel.TextScaled = true
	textLabel.Parent = popupGui

	if amount >= 0 then
		textLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
		textLabel.Text = "+" .. amount .. " Moedas (" .. reason .. ")"
	else
		textLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
		textLabel.Text = tostring(amount) .. " Moedas (" .. reason .. ")"
	end

	TweenService:Create(textLabel, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.new(0.3, 0, 0.1, 0),
		TextTransparency = 1,
	}):Play()

	if mainCoinLabel and typeof(totalCoins) == "number" then
		mainCoinLabel.Text = "Moedas: " .. tostring(totalCoins)
	end

	task.delay(1.5, function()
		if popupGui then
			popupGui:Destroy()
		end
	end)
end

