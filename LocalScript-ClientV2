evTransition.OnClientEvent:Connect(function(action, value)
	local tweenInfo = TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	if action == "FadeIn" then
		TweenService:Create(blackScreen, tweenInfo, {BackgroundTransparency = 0}):Play()
	elseif action == "FadeOut" then
		TweenService:Create(blackScreen, tweenInfo, {BackgroundTransparency = 1}):Play()
		TweenService:Create(countText, tweenInfo, {TextTransparency = 1}):Play()
	elseif action == "Countdown" then
		task.spawn(function()
			TweenService:Create(countText, tweenInfo, {TextTransparency = 0}):Play()
			for i = value, 1, -1 do
				countText.Text = tostring(i)
				countText.Size = UDim2.new(1.2, 0, 1.2, 0)
				TweenService:Create(countText, TweenInfo.new(0.3, Enum.EasingStyle.Bounce), {Size = UDim2.new(1, 0, 1, 0)}):Play()
				task.wait(1)
			end
			countText.Text = "VAI!"
			task.wait(0.5)
		end)
	end
end)

