deathAnimEvent.OnClientEvent:Connect(function(victimChar, killerChar, arg3, arg4, duration)
	-- Adaptação para suportar diferentes animações de morte baseadas no tipo de Killer
	local victimAnimId = arg3
	local killerAnimId = arg4

	-- Se o servidor enviou o nome do Killer (ex: "Killer1") no lugar da animação da vítima
	if type(arg3) == "string" and DEATH_ANIMS[arg3] then
		victimAnimId = DEATH_ANIMS[arg3].Victim
		killerAnimId = DEATH_ANIMS[arg3].Killer
		duration = arg4 or 2.25
		-- Ou se o Killer possui um atributo no Character definindo seu tipo
	elseif killerChar and killerChar:GetAttribute("KillerType") and DEATH_ANIMS[killerChar:GetAttribute("KillerType")] then
		local kType = killerChar:GetAttribute("KillerType")
		victimAnimId = DEATH_ANIMS[kType].Victim
		killerAnimId = DEATH_ANIMS[kType].Killer
	end

	duration = duration or 2.25

	if not victimChar or not killerChar then return end
	if executingDeaths[victimChar] then return end
	executingDeaths[victimChar] = true

	local victimHum = victimChar:FindFirstChildOfClass("Humanoid")
	local killerHum = killerChar:FindFirstChildOfClass("Humanoid")
	local victimRoot = victimChar:FindFirstChild("HumanoidRootPart") or victimChar:FindFirstChild("Torso")
	local killerRoot = killerChar:FindFirstChild("HumanoidRootPart") or killerChar:FindFirstChild("Torso")

	if not victimHum or not killerHum or not victimRoot or not killerRoot then
		executingDeaths[victimChar] = nil
		return
	end

	victimHum.AutoRotate = false
	killerHum.AutoRotate = false
	victimRoot.Anchored = true
	killerRoot.Anchored = true

	victimRoot.CFrame = CFrame.lookAt(victimRoot.Position, Vector3.new(killerRoot.Position.X, victimRoot.Position.Y, killerRoot.Position.Z))

	local oppositeLook = CFrame.lookAt(killerRoot.Position, Vector3.new(victimRoot.Position.X, killerRoot.Position.Y, victimRoot.Position.Z))
	killerRoot.CFrame = oppositeLook

	local victimTrack = playCharacterAnim(victimChar, victimAnimId, 0.05, 1)
	local killerTrack = playCharacterAnim(killerChar, killerAnimId, 0.05, 1)

	task.delay(duration, function()
		if victimRoot and victimRoot.Parent then victimRoot.Anchored = false end
		if killerRoot and killerRoot.Parent then killerRoot.Anchored = false end
		if victimHum and victimHum.Parent then victimHum.AutoRotate = true end
		if killerHum and killerHum.Parent then killerHum.AutoRotate = true end

		if victimTrack then pcall(function() victimTrack:Stop(0.1) end) end
		if killerTrack then pcall(function() killerTrack:Stop(0.1) end) end

		executingDeaths[victimChar] = nil
	end)
end)

local function use(ability)
	if isExecutingAny then return end 
	if tick() - cd[ability] < times[ability] then return end

	isExecutingAny = true
	cd[ability] = tick()

	task.spawn(function()
		if ability == "Blood" then
			playAnim(ANIMS.Blood, 0.5)
			killerEvents.Blood:FireServer()
		elseif ability == "Hunter" then
			playAnim(ANIMS.Hunter, 5)
			killerEvents.Hunter:FireServer()
		elseif ability == "Corruption" then
			playAnim(ANIMS.Corruption, 1)
			killerEvents.Corruption:FireServer()
		elseif ability == "Reveal" then
			TweenService:Create(camera, TweenInfo.new(0.5), {FieldOfView = 100}):Play()
			playAnim(ANIMS.Reveal, 2)
			killerEvents.Reveal:FireServer()
			task.delay(0.5, function()
				if camera then
					TweenService:Create(camera, TweenInfo.new(0.5), {FieldOfView = 70}):Play()
				end
			end)
		end

		isExecutingAny = false
	end)
end

UserInputService.InputBegan:Connect(function(input, proc)
	if proc then return end

	if ui.Enabled then
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			use("Blood")
		elseif input.KeyCode == Enum.KeyCode.E then
			use("Hunter")
		elseif input.KeyCode == Enum.KeyCode.R then
			use("Corruption")
		elseif input.KeyCode == Enum.KeyCode.F then
			use("Reveal")
		end
	else
		if input.KeyCode == Enum.KeyCode.E and currentSpecialMode == "OneBounce" and not string.find(gameStatus.Value, "Intermissão") and gameStatus.Value ~= "Preparando a arena..." then
			if tick() - cd.Dash >= times.Dash then
				cd.Dash = tick()
				evDash:FireServer()
			end
		end
	end
end)

