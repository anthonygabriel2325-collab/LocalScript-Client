	if ui.Enabled then
		updateAbilityUI()
	end
end)

local function playAnim(id, duration)
	local char = player.Character
	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum or id == "" then return end

	local animator = hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)
	local anim = Instance.new("Animation")
	anim.AnimationId = id

	local success, track = pcall(function()
		return animator:LoadAnimation(anim)
	end)

	if success and track then
		track.Looped = false
		track:Play()
	end

	task.wait(duration)
end

local function playCharacterAnim(character, animId, fadeTime, speed)
	if not character or not animId or animId == "" then return nil end

	local hum = character:FindFirstChildOfClass("Humanoid")
	if not hum then return nil end

	local animator = hum:FindFirstChildOfClass("Animator")
	if not animator then
		animator = Instance.new("Animator")
		animator.Parent = hum
	end

	local anim = Instance.new("Animation")
	anim.AnimationId = animId

	local ok, track = pcall(function()
		return animator:LoadAnimation(anim)
	end)

	if ok and track then
		track.Priority = Enum.AnimationPriority.Action
		track.Looped = false
		track:Play(fadeTime or 0.05, 1, speed or 1)
		return track
	end

	return nil
end

local executingDeaths = {}
local victoryShieldObject = nil
local charConns = {}

local function clearVictoryShield()
	if victoryShieldObject and victoryShieldObject.Parent then
		victoryShieldObject:Destroy()
	end
	victoryShieldObject = nil
end

local function clearCharacterBindings()
	for _, c in ipairs(charConns) do
		if c and c.Disconnect then
			c:Disconnect()
		end
	end
	table.clear(charConns)
end

local function createVictoryShield(character, duration)
	duration = duration or 2.5
	if not character then return end

	clearVictoryShield()

	local hum = character:FindFirstChildOfClass("Humanoid")
	local hrp = character:FindFirstChild("HumanoidRootPart")
	if not hum or not hrp then return end

	local ff = Instance.new("ForceField")
	ff.Visible = false
	ff.Parent = character

	local shield = Instance.new("Part")
	shield.Name = "VictoryShield"
	shield.Shape = Enum.PartType.Ball
	shield.Size = Vector3.new(9, 9, 9)
	shield.Material = Enum.Material.ForceField
	shield.Color = Color3.fromRGB(0, 170, 255)
	shield.Transparency = 0.45
	shield.CanCollide = false
	shield.CanTouch = false
	shield.CanQuery = false
	shield.Massless = true
	shield.CastShadow = false
	shield.Parent = character
	shield.CFrame = hrp.CFrame

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = hrp
	weld.Part1 = shield
	weld.Parent = shield

	victoryShieldObject = shield

	task.delay(duration, function()
		if ff and ff.Parent then
			ff:Destroy()
		end
		if shield and shield.Parent then
			shield:Destroy()
		end
		if victoryShieldObject == shield then
			victoryShieldObject = nil
		end
	end)
end

local function bindCharacter(char)
	clearCharacterBindings()
	clearVictoryShield()
	if char then
		executingDeaths[char] = nil
	end

	table.insert(charConns, char.AncestryChanged:Connect(function(_, parent)
		if not parent then
			executingDeaths[char] = nil
			clearVictoryShield()
		end
	end))

	local hum = char:WaitForChild("Humanoid", 5)
	if hum then
		table.insert(charConns, hum.Died:Connect(function()
			clearVictoryShield()
		end))
	end
end

player.CharacterAdded:Connect(bindCharacter)
player.CharacterRemoving:Connect(function(char)
	if char then
		executingDeaths[char] = nil
	end
	clearCharacterBindings()
	clearVictoryShield()
end)
if player.Character then
	bindCharacter(player.Character)
end

