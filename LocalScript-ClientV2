local function updateAbilityUI()
	for name, btn in pairs(abilityButtons) do
		local label = btn:FindFirstChild("KeyBindLabel")
		local lockIcon = btn:FindFirstChild("LockIcon")

		if not label then continue end

		local timeLeft = times[name] - (tick() - cd[name])

		if isExecutingAny then
			if lockIcon then lockIcon.Visible = true end
			label.Visible = false
			btn.ImageColor3 = Color3.fromRGB(100, 100, 100)
		elseif timeLeft > 0 then
			if lockIcon then lockIcon.Visible = false end
			label.Visible = true
			label.Text = math.ceil(timeLeft) .. "s"
			btn.ImageColor3 = Color3.fromRGB(150, 100, 100)
		else
			if lockIcon then lockIcon.Visible = false end
			label.Visible = true
			label.Text = originalKeys[name]
			btn.ImageColor3 = Color3.fromRGB(255, 255, 255)
		end
	end
end

